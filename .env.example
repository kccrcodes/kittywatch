# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project settings — API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HuggingFace access token — huggingface.co/settings/tokens
# (currently unused in the app itself; scripts/derisk-clip.mjs falls back to
# local CLIP since HF's hosted Inference API doesn't support raw embeddings)
HF_TOKEN=

# Shared-secret bearer token gating POST /api/admin/run-check - generate any
# random string (e.g. `openssl rand -hex 32`). Required; the route fails
# closed (500) if this isn't set, rather than allowing unauthenticated access.
ADMIN_RUN_CHECK_TOKEN=
